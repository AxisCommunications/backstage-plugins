{
  "extends": "@backstage/cli/config/tsconfig.json",
  "include": [
    "packages/*/src",
    "plugins/*/src",
    "plugins/*/dev",
    "plugins/*/migrations",
    "src"
  ],
  "exclude": ["node_modules"],
  "compilerOptions": {
    "jsx": "react-jsx",
    "outDir": "dist-types",
    "rootDir": ".",
    "allowSyntheticDefaultImports": true,
    "sourceMap": true,
    "moduleResolution": "bundler",
    "types": ["node", "jest"]
  }
}
